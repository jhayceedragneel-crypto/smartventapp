<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/activity_stats_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <FrameLayout android:id="@+id/btnBackContainer"
                android:layout_width="40dp" android:layout_height="40dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_back" app:tint="#FFFFFF"/>
            </FrameLayout>

            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginStart="10dp"
                android:text="7-Day Stats" android:textColor="#FFFFFF"
                android:textSize="20sp" android:textStyle="bold"/>

            <FrameLayout android:id="@+id/menu_container"
                android:layout_width="40dp" android:layout_height="40dp">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_menu" app:tint="#AAAAAA"/>
            </FrameLayout>
        </LinearLayout>

        <!-- Weather animation background -->
        <com.example.smartventapp.WeatherAnimationView
            android:id="@+id/weather_anim"
            android:layout_width="match_parent"
            android:layout_height="100dp"/>

        <!-- Loading / error -->
        <TextView android:id="@+id/tvLoading"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Loading…" android:textColor="#888888"
            android:textSize="14sp" android:gravity="center"
            android:visibility="gone"/>

        <!-- ── Weekly Summary Cards ── -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="This Week" android:textColor="#AAAAAA"
            android:textSize="12sp" android:layout_marginBottom="8dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:weightSum="3"
            android:layout_marginBottom="16dp">

            <!-- Avg Temp -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginEnd="6dp"
                app:cardBackgroundColor="#1A1A1A" app:cardCornerRadius="14dp"
                xmlns:app="http://schemas.android.com/apk/res-auto">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Avg Temp" android:textColor="#666666" android:textSize="10sp"/>
                    <TextView android:id="@+id/tvAvgTemp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="--°C" android:textColor="#FFEE00"
                        android:textSize="20sp" android:textStyle="bold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Avg Humidity -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginEnd="6dp"
                app:cardBackgroundColor="#1A1A1A" app:cardCornerRadius="14dp"
                xmlns:app="http://schemas.android.com/apk/res-auto">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Avg Humidity" android:textColor="#666666" android:textSize="10sp"/>
                    <TextView android:id="@+id/tvAvgHum"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="--%"
                        android:textColor="#00E5FF" android:textSize="20sp" android:textStyle="bold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Hottest Day -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardBackgroundColor="#1A1A1A" app:cardCornerRadius="14dp"
                xmlns:app="http://schemas.android.com/apk/res-auto">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Hottest Day" android:textColor="#666666" android:textSize="10sp"/>
                    <TextView android:id="@+id/tvHottestDay"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#FF7043" android:textSize="13sp" android:textStyle="bold"
                        android:gravity="center"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- ── Fan Usage Card ── -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Today's Fan Usage" android:textColor="#AAAAAA"
            android:textSize="12sp" android:layout_marginBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#1A1A1A" app:cardCornerRadius="14dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="16dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Hours Run" android:textColor="#666666" android:textSize="11sp"/>
                    <TextView android:id="@+id/tvFanHours"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0.0 hrs" android:textColor="#FFFFFF"
                        android:textSize="22sp" android:textStyle="bold"/>
                </LinearLayout>
                <View android:layout_width="0.5dp" android:layout_height="match_parent"
                    android:background="#2A2A2A"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Est. Cost" android:textColor="#666666" android:textSize="11sp"/>
                    <TextView android:id="@+id/tvFanCost"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="₱0.00" android:textColor="#00FF88"
                        android:textSize="22sp" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Auto fan reason -->
        <TextView android:id="@+id/tvAutoFanReason"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="" android:textColor="#666666" android:textSize="11sp"
            android:layout_marginBottom="16dp" android:visibility="gone"/>

        <!-- ── Temperature Chart ── -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Temperature (7 days)" android:textColor="#AAAAAA"
            android:textSize="12sp" android:layout_marginBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#141414" app:cardCornerRadius="14dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">
            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/chartTemp"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:padding="8dp"/>
        </androidx.cardview.widget.CardView>

        <!-- ── Humidity Chart ── -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Humidity (7 days)" android:textColor="#AAAAAA"
            android:textSize="12sp" android:layout_marginBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="#141414" app:cardCornerRadius="14dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">
            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/chartHumidity"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:padding="8dp"/>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>