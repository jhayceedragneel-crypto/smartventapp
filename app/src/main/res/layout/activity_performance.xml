<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/activity_performance_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080808"
    tools:context=".PerformanceActivity">

    <!-- Animation Layer -->
    <com.example.smartventapp.WeatherAnimationView
        android:id="@+id/weather_anim"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Header / Menu Selector (Static for Performance) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/menu_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginTop="44dp"
        android:background="@drawable/dark_pill"
        android:paddingHorizontal="14dp"
        android:paddingVertical="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/menu_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Performance"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/grid_icon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_grid"
            app:layout_constraintBottom_toBottomOf="@id/menu_name"
            app:layout_constraintStart_toEndOf="@id/menu_name"
            app:layout_constraintTop_toTopOf="@id/menu_name"
            app:tint="#555555" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Location -->
    <TextView
        android:id="@+id/location_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="18dp"
        android:text="Manila, PH"
        android:textColor="#444444"
        android:textSize="11sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/menu_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/menu_container" />

    <!-- Back Button -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/btnBackContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/dark_card"
        android:padding="10dp"
        app:layout_constraintStart_toStartOf="@+id/menu_container"
        app:layout_constraintTop_toBottomOf="@+id/menu_container">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_snowflake"
            android:rotation="180"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#FFFFFF" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Scrollable Air Quality Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:paddingBottom="24dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBackContainer">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <!-- Main Air Quality Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="#161616"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#1E1E1E"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:id="@+id/perf_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Air Quality Control"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="14dp" />

                    <!-- AQI + CO2 row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="14dp">

                        <androidx.cardview.widget.CardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            app:cardBackgroundColor="#101010"
                            app:cardCornerRadius="10dp"
                            app:cardElevation="0dp"
                            app:strokeColor="#1E1E1E"
                            app:strokeWidth="1dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="12dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="AQI"
                                    android:textColor="#444444"
                                    android:textSize="10sp"
                                    android:textAllCaps="true"
                                    android:layout_marginBottom="4dp" />
                                <TextView
                                    android:id="@+id/tvAqi"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="42"
                                    android:textColor="#00E5A0"
                                    android:textSize="26sp"
                                    android:textStyle="bold" />
                                <TextView
                                    android:id="@+id/tvAqiLabel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Good"
                                    android:textColor="#00E5A0"
                                    android:textSize="10sp"
                                    android:layout_marginTop="3dp" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <androidx.cardview.widget.CardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="4dp"
                            app:cardBackgroundColor="#101010"
                            app:cardCornerRadius="10dp"
                            app:cardElevation="0dp"
                            app:strokeColor="#1E1E1E"
                            app:strokeWidth="1dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="12dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="CO₂"
                                    android:textColor="#444444"
                                    android:textSize="10sp"
                                    android:textAllCaps="true"
                                    android:layout_marginBottom="4dp" />
                                <TextView
                                    android:id="@+id/tvCo2"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="612"
                                    android:textColor="#FFFFFF"
                                    android:textSize="26sp"
                                    android:textStyle="bold" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="ppm"
                                    android:textColor="#444444"
                                    android:textSize="10sp"
                                    android:layout_marginTop="3dp" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>

                    <!-- Methane Sensor -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Methane Sensor"
                            android:textColor="#444444"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tvMethaneStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Safe"
                            android:textColor="#00E5A0"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                    <ProgressBar
                        android:id="@+id/progressMethane"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginBottom="14dp"
                        android:max="100"
                        android:progress="12"
                        android:progressTint="#00E5A0"
                        android:progressBackgroundTint="#252525" />

                    <!-- Filter Efficiency -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Filter Efficiency"
                            android:textColor="#444444"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tvFilterEfficiency"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="85%"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                    <ProgressBar
                        android:id="@+id/progressFilter"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginBottom="14dp"
                        android:max="100"
                        android:progress="85"
                        android:progressTint="#00CCB0"
                        android:progressBackgroundTint="#252525" />

                    <!-- Humidity -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Humidity"
                            android:textColor="#444444"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tvHumidityValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="56%"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                    <ProgressBar
                        android:id="@+id/progressHumidity"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginBottom="16dp"
                        android:max="100"
                        android:progress="56"
                        android:progressTint="#00B8CC"
                        android:progressBackgroundTint="#252525" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#1E1E1E"
                        android:layout_marginBottom="14dp" />

                    <!-- Fan Speed -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fan Speed"
                        android:textColor="#444444"
                        android:textSize="12sp"
                        android:layout_marginBottom="6dp" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="bottom"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:id="@+id/tvFanSpeed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2400"
                            android:textColor="#FFFFFF"
                            android:textSize="32sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" RPM"
                            android:textColor="#444444"
                            android:textSize="13sp"
                            android:layout_marginBottom="4dp" />
                    </LinearLayout>
                    <ProgressBar
                        android:id="@+id/progressFanSpeed"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:max="100"
                        android:progress="60"
                        android:progressTint="#00B8CC"
                        android:progressBackgroundTint="#252525" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Vent Mode + Status row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    app:cardBackgroundColor="#161616"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#1E1E1E"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="VENT MODE"
                            android:textColor="#444444"
                            android:textSize="10sp"
                            android:layout_marginBottom="6dp" />
                        <TextView
                            android:id="@+id/tvVentMode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dual-Flow"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    app:cardBackgroundColor="#161616"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#1E1E1E"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="STATUS"
                            android:textColor="#444444"
                            android:textSize="10sp"
                            android:layout_marginBottom="6dp" />
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <View
                                android:layout_width="6dp"
                                android:layout_height="6dp"
                                android:background="@drawable/glow_dot"
                                android:layout_marginEnd="5dp" />
                            <TextView
                                android:id="@+id/tvStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Active"
                                android:textColor="#00E5A0"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
