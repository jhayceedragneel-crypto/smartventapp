<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/activity_main_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    tools:context=".MainActivity">

    <!-- Animation Layer -->
    <com.example.smartventapp.WeatherAnimationView
        android:id="@+id/weather_anim"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Header / Menu Selector -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/menu_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="40dp"
        android:background="@drawable/dark_card"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/menu_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dashboard"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/grid_icon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_grid"
            app:layout_constraintBottom_toBottomOf="@id/menu_name"
            app:layout_constraintStart_toEndOf="@id/menu_name"
            app:layout_constraintTop_toTopOf="@id/menu_name"
            app:tint="@color/white" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Outdoor Weather Data Display -->
    <LinearLayout
        android:id="@+id/outdoor_weather_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:gravity="end"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/menu_container">

        <TextView
            android:id="@+id/location_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Manila, PH"
            android:textColor="@color/text_grey"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Air Quality Badge -->
    <TextView
        android:id="@+id/tvAirQualityBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/dark_card"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:text="● Good"
        android:textColor="#00FF88"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/master_switch_container" />

    <!-- Master Switch -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/master_switch_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/dark_card"
        android:padding="12dp"
        app:layout_constraintStart_toStartOf="@+id/menu_container"
        app:layout_constraintTop_toBottomOf="@+id/menu_container">

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/offonbtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:thumbTint="@color/white"
            app:trackTint="@color/neon_blue" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Temperature Display -->
    <LinearLayout
        android:id="@+id/temp_display_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/unit_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="°F"
            android:textColor="@color/white"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/temp_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="@color/white"
            android:textSize="100sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_humidity"
                app:tint="@color/text_grey" />

            <TextView
                android:id="@+id/humidity_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="--%"
                android:textColor="@color/text_grey"
                android:textSize="18sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Large Colorful Gauge -->

    <!-- Indoor vs Outdoor Cards -->

    <com.example.smartventapp.DialTicksView
        android:id="@+id/dial_ticks"
        android:layout_width="364dp"
        android:layout_height="334dp"
        android:layout_marginEnd="-150dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.173" />

    <LinearLayout
        android:id="@+id/indoor_outdoor_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="12dp"
        android:orientation="horizontal"
        android:weightSum="2"
        app:layout_constraintBottom_toTopOf="@+id/bottom_controls"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Indoor Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="14dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏠 Indoor"
                    android:textColor="#888888"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/tvIndoorTemp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--°C"
                    android:textColor="@color/white"
                    android:textSize="24sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvIndoorHum"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--%"
                    android:textColor="#00E5FF"
                    android:textSize="13sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Outdoor Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="14dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌤 Outdoor"
                    android:textColor="#888888"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/tvOutdoorTemp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--°C"
                    android:textColor="@color/white"
                    android:textSize="24sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvOutdoorHum"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--%"
                    android:textColor="#00E5FF"
                    android:textSize="13sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Bottom Controls -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottom_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Timer Card (replaces Auto) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/timerCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/dark_card"
            android:padding="16dp"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Left: label + countdown display -->
            <LinearLayout
                android:id="@+id/timerLeftGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fan Timer"
                    android:textColor="@color/text_grey"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvTimerDisplay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--:--"
                    android:textColor="#00E5FF"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Right: minus / minutes / plus / start -->
            <LinearLayout
                android:id="@+id/timerControls"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <FrameLayout
                    android:id="@+id/btnTimerMinus"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/dark_card"
                    android:backgroundTint="#1E1E1E">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="−"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvTimerMinutes"
                    android:layout_width="42dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    android:text="30 min"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:textStyle="bold" />

                <FrameLayout
                    android:id="@+id/btnTimerPlus"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/dark_card"
                    android:backgroundTint="#1E1E1E">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="+"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/btnTimerStart"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/dark_card"
                    android:backgroundTint="#003333"
                    android:paddingHorizontal="14dp">
                    <TextView
                        android:id="@+id/tvTimerStartLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="Start"
                        android:textColor="#00E5FF"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </FrameLayout>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Mode Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/timerCard">

            <FrameLayout
                android:id="@+id/mode_cooling"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/dark_card"
                android:backgroundTint="#004D40">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_snowflake"
                    app:tint="@color/neon_green" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/mode_turbo"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/dark_card">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_auto"
                    app:tint="@color/white" />
            </FrameLayout>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>