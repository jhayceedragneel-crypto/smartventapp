<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/activity_main_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- Weather animation layer (behind everything) -->
    <com.example.smartventapp.WeatherAnimationView
        android:id="@+id/weather_anim"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ── TOP BAR ─────────────────────────────────────────────────────── -->

    <!-- Menu button (top-left) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/menu_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="44dp"
        android:background="@drawable/dark_card"
        android:paddingHorizontal="14dp"
        android:paddingVertical="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/menu_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SmartVent"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginStart="6dp"
            android:src="@drawable/ic_grid"
            app:layout_constraintBottom_toBottomOf="@id/menu_name"
            app:layout_constraintStart_toEndOf="@id/menu_name"
            app:layout_constraintTop_toTopOf="@id/menu_name"
            app:tint="#AAAAAA" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- BT status pill (top-right) -->
    <TextView
        android:id="@+id/tvBtStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="44dp"
        android:background="@drawable/dark_card"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:text="● BT Off"
        android:textColor="#888888"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Fan ON/OFF switch — below menu, top-left -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/master_switch_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/dark_card"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        app:layout_constraintStart_toStartOf="@id/menu_container"
        app:layout_constraintTop_toBottomOf="@id/menu_container">

        <!--
            FIX: trackTintList with a selector drawable removes the blue
            when OFF. Use @drawable/switch_track_tint (create this file).

            Quick inline fix: set both checked + unchecked tints here.
            The Java code must NOT set trackTint programmatically.
        -->
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/offonbtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="false"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:thumbTint="#FFFFFF"
            app:trackTint="@color/switch_track_selector" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Air quality badge — below switch -->
    <TextView
        android:id="@+id/tvAirQualityBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/dark_card"
        android:paddingHorizontal="10dp"
        android:paddingVertical="5dp"
        android:text="● Good"
        android:textColor="#00FF88"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@id/menu_container"
        app:layout_constraintTop_toBottomOf="@id/master_switch_container" />

    <!-- ── TEMPERATURE DISPLAY (left-center) ───────────────────────────── -->
    <LinearLayout
        android:id="@+id/temp_display_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.38">

        <TextView
            android:id="@+id/unit_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="°C"
            android:textColor="#CCCCCC"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/temp_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#FFFFFF"
            android:textSize="96sp"
            android:textStyle="bold"
            android:lineSpacingExtra="-8dp" />

        <!-- Humidity row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_humidity"
                app:tint="#888888" />

            <TextView
                android:id="@+id/humidity_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="--%"
                android:textColor="#888888"
                android:textSize="18sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- ── DIAL (right-center) ─────────────────────────────────────────── -->
    <com.example.smartventapp.DialTicksView
        android:id="@+id/dial_ticks"
        android:layout_width="340dp"
        android:layout_height="310dp"
        android:layout_marginEnd="-140dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.20" />

    <!-- ── INDOOR / OUTDOOR SENSOR CARDS ───────────────────────────────── -->
    <LinearLayout
        android:id="@+id/indoor_outdoor_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="10dp"
        android:orientation="horizontal"
        android:weightSum="2"
        app:layout_constraintBottom_toTopOf="@id/bottom_controls"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Indoor: temp + humidity from Arduino sensor -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="5dp"
            android:layout_weight="1"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏠 Indoor"
                    android:textColor="#666666"
                    android:textSize="11sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvIndoorTemp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--°C"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvIndoorHum"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--%"
                    android:textColor="#00E5FF"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#2A2A2A"
                    android:layout_marginVertical="8dp" />

                <!-- Gas sensors under indoor -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GAS SENSORS"
                    android:textColor="#444444"
                    android:textSize="9sp"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Gas 1"
                        android:textColor="#555555"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tvGas1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#FFCC00"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="3dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Gas 2"
                        android:textColor="#555555"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tvGas2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#FFCC00"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Outdoor: placeholder (no outdoor sensor) -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:layout_weight="1"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌤 Outdoor"
                    android:textColor="#666666"
                    android:textSize="11sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvOutdoorTemp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--°C"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvOutdoorHum"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--%"
                    android:textColor="#00E5FF"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#2A2A2A"
                    android:layout_marginVertical="8dp" />

                <!-- Fan status row -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FAN STATUS"
                    android:textColor="#444444"
                    android:textSize="9sp"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="4dp" />

                <!-- Fan on indicator dot + label -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="State"
                        android:textColor="#555555"
                        android:textSize="11sp" />

                    <!-- This TextView is updated by Java when fan flips -->
                    <TextView
                        android:id="@+id/tvFanStatusLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="OFF"
                        android:textColor="#FF5555"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Timer remaining row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginTop="3dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Timer"
                        android:textColor="#555555"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tvOutdoorTimerEcho"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--:--"
                        android:textColor="#00E5FF"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- ── BOTTOM CONTROLS (timer) ──────────────────────────────────────── -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottom_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="36dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!--
            Timer card
            Starting the timer turns the fan ON.
            When countdown hits 00:00 the fan turns OFF automatically.
        -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/timerCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/dark_card"
            android:padding="16dp"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Left: label + countdown -->
            <LinearLayout
                android:id="@+id/timerLeftGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fan Timer"
                    android:textColor="#666666"
                    android:textSize="11sp" />

                <!-- Countdown — synced with fan on/off -->
                <TextView
                    android:id="@+id/tvTimerDisplay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--:--"
                    android:textColor="#00E5FF"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

                <!-- Small label: turns off fan when done -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="auto-off when done"
                    android:textColor="#444444"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- Right: − / minutes / + / Start|Cancel -->
            <LinearLayout
                android:id="@+id/timerControls"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <FrameLayout
                    android:id="@+id/btnTimerMinus"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/dark_card"
                    android:backgroundTint="#222222">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="−"
                        android:textColor="#CCCCCC"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvTimerMinutes"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    android:gravity="center"
                    android:text="30 min"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <FrameLayout
                    android:id="@+id/btnTimerPlus"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/dark_card"
                    android:backgroundTint="#222222">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="+"
                        android:textColor="#CCCCCC"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <!-- Start / Cancel button — teal when start, red when running -->
                <FrameLayout
                    android:id="@+id/btnTimerStart"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/dark_card"
                    android:backgroundTint="#003333"
                    android:paddingHorizontal="16dp">
                    <TextView
                        android:id="@+id/tvTimerStartLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="Start"
                        android:textColor="#00E5FF"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </FrameLayout>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>